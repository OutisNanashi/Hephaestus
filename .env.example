# Hephaestus local environment (EXAMPLE — placeholders only, no real values).
# Copy this file to `.env` and fill in real values locally.
# `.env` is git-ignored (see .gitignore) and must never be committed.

# --- GPT brain provider (OpenAI) ---
# Required by `hephaestus live-brain`. The config's brain.apiKeyEnv must
# reference OPENAI_API_KEY (the only accepted name). Also requires a
# "brain": { "provider": "openai", "model": "<model-id>" } block in the
# active hephaestus.config.json before live-brain will run.
OPENAI_API_KEY=

# Optional brain provider override; defaults to "openai" when unset.
# HEPHAESTUS_BRAIN_PROVIDER=openai

# --- Telegram notifications (optional) ---
# Only used when the active config sets notifications.telegram.enabled=true and
# points botTokenEnv / chatIdEnv at these variable names. Hephaestus reads env
# var NAMES from config; it never stores literal tokens in config. Tokens/chat
# IDs are redacted from all reports, logs, and rendered messages.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
